{
  "version": "0.10.7",
  "description": "A package manager for C",
  "homepage": "https://github.com/Oblivious-Oblivious/Emeralds",
  "license": "MIT",
  "url": "https://github.com/Oblivious-Oblivious/Emeralds/archive/refs/tags/v0.10.7.zip",
  "hash": "56cfd63c26c9387c25f5fc77d9336712505873214e12dbd42ca74bcd799d3583",
  "depends": [
    "crystal",
    "git"
  ],
  "install": {
    "script": [
      "Set-Location $dir",
      "shards install",
      "shards build --release --no-debug",
      "Copy-Item bin\\emeralds.exe emeralds.exe",
      "Copy-Item bin\\emeralds.exe em.exe"
    ]
  },
  "bin": [
    "emeralds.exe",
    "em.exe"
  ]
}
