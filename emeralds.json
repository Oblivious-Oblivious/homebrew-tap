{
  "version": "0.10.10",
  "description": "A package manager for C",
  "homepage": "https://github.com/Oblivious-Oblivious/Emeralds",
  "license": "MIT",
  "url": "https://github.com/Oblivious-Oblivious/Emeralds/archive/refs/tags/v0.10.10.zip",
  "hash": "32cdc56d85236fcd25a246f7f75ffd51950d0fd9cdf4976a5066dfcef0a87fa1",
  "depends": [
    "crystal",
    "git"
  ],
  "installer": {
    "script": [
      "Set-Location $dir",
      "shards install",
      "shards build --release --no-debug",
      "Copy-Item bin\\emeralds.exe emeralds.exe",
      "Copy-Item bin\\emeralds.exe em.exe"
    ]
  },
  "bin": [
    "emeralds.exe",
    "em.exe"
  ]
}
