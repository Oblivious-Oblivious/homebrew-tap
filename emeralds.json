{
  "version": "0.10.6",
  "description": "A package manager for C",
  "homepage": "https://github.com/Oblivious-Oblivious/Emeralds",
  "license": "MIT",
  "url": "https://github.com/Oblivious-Oblivious/Emeralds/archive/refs/tags/v0.10.6.zip",
  "hash": "3dd4426d7b5fd122def67f1bf3e2ec63afc3dd8c1d86d94060d81cd490cde1af",
  "depends": [
    "crystal",
    "git"
  ],
  "install": {
    "script": [
      "Set-Location $dir",
      "shards install",
      "shards build --release --no-debug",
      "Copy-Item bin\\emeralds.exe emeralds.exe",
      "Copy-Item bin\\emeralds.exe em.exe"
    ]
  },
  "bin": [
    "emeralds.exe",
    "em.exe"
  ]
}
