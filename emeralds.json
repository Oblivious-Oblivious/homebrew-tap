{
  "version": "0.10.11",
  "description": "A package manager for C",
  "homepage": "https://github.com/Oblivious-Oblivious/Emeralds",
  "license": "MIT",
  "url": "https://github.com/Oblivious-Oblivious/Emeralds/archive/refs/tags/v0.10.11.zip",
  "hash": "7a68508cc840cdf3fd0eb584bf04d2ede526a3cfb279b84d1f59581be248fb38",
  "depends": [
    "crystal",
    "git"
  ],
  "installer": {
    "script": [
      "Set-Location $dir",
      "shards install",
      "shards build --release --no-debug",
      "Copy-Item bin\\emeralds.exe emeralds.exe",
      "Copy-Item bin\\emeralds.exe em.exe"
    ]
  },
  "bin": [
    "emeralds.exe",
    "em.exe"
  ]
}
