{
  "version": "0.10.8",
  "description": "A package manager for C",
  "homepage": "https://github.com/Oblivious-Oblivious/Emeralds",
  "license": "MIT",
  "url": "https://github.com/Oblivious-Oblivious/Emeralds/archive/refs/tags/v0.10.8.zip",
  "hash": "ba332719d10446074b65d54a1f290e92136414077f12db28cffd300e587dcd08",
  "depends": [
    "crystal",
    "git"
  ],
  "installer": {
    "script": [
      "Set-Location $dir",
      "shards install",
      "shards build --release --no-debug",
      "Copy-Item bin\\emeralds.exe emeralds.exe",
      "Copy-Item bin\\emeralds.exe em.exe"
    ]
  },
  "bin": [
    "emeralds.exe",
    "em.exe"
  ]
}
