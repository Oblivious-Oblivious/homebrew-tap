  "depends": [
    "git",
    "https://raw.githubusercontent.com/neatorobito/scoop-crystal/main/bucket/vs_2022_cpp_build_tools.json",
    "crystal"
  ],
  "installer": {
    "script": [
      "Set-Location (Join-Path $dir 'Emeralds-0.10.13')",
      "shards install",
      "shards build --release --no-debug",
